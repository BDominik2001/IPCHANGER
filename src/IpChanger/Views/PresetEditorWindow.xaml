<Window x:Class="IpChanger.Views.PresetEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}" Height="600" Width="460"
        MinHeight="560" MinWidth="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource BackgroundBrush}"
        FontFamily="Segoe UI">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding Title}" Style="{StaticResource HeaderText}"
                   Margin="0,0,0,16" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Név -->
                <Label Content="Preset neve" />
                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,14" />

                <!-- DHCP kapcsoló -->
                <CheckBox Content="IP cím automatikus lekérése (DHCP)"
                          IsChecked="{Binding UseDhcp}" Margin="0,0,0,14" />

                <!-- Statikus IP mezők -->
                <StackPanel IsEnabled="{Binding IsStatic}">
                    <Label Content="IP cím" />
                    <TextBox Text="{Binding IpAddress, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" />

                    <Label Content="Alhálózati maszk" />
                    <TextBox Text="{Binding SubnetMask, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" />

                    <Label Content="Alapértelmezett átjáró (opcionális)" />
                    <TextBox Text="{Binding Gateway, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,14" />

                    <!-- DNS kapcsoló -->
                    <CheckBox Content="DNS automatikus lekérése (DHCP)"
                              IsChecked="{Binding DnsFromDhcp}" Margin="0,0,0,12" />

                    <StackPanel IsEnabled="{Binding IsStaticDns}">
                        <Label Content="Elsődleges DNS (opcionális)" />
                        <TextBox Text="{Binding PreferredDns, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" />

                        <Label Content="Másodlagos DNS (opcionális)" />
                        <TextBox Text="{Binding AlternateDns, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,14" />
                    </StackPanel>
                </StackPanel>

                <!-- Megjegyzés -->
                <Label Content="Megjegyzés" />
                <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         MinHeight="80" MaxHeight="160" />
            </StackPanel>
        </ScrollViewer>

        <!-- Gombok -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Mégse" IsCancel="True" MinWidth="90" Margin="0,0,10,0" Click="OnCancel" />
            <Button Content="Mentés" Style="{StaticResource AccentButton}" MinWidth="110"
                    IsDefault="True" Click="OnSave" />
        </StackPanel>
    </Grid>
</Window>
