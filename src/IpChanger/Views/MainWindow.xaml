<Window x:Class="IpChanger.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:IpChanger.Converters"
        Title="IP Changer" Height="640" Width="1000"
        MinHeight="520" MinWidth="820"
        Icon="/Assets/app.ico"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}"
        FontFamily="Segoe UI">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ============ Fejléc ============ -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="IP Changer" Style="{StaticResource HeaderText}" FontSize="22" />
                <TextBlock Text="{DynamicResource L.Subtitle}"
                           Style="{StaticResource CaptionText}" Margin="0,2,0,0" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <!-- Nyelvválasztó (magyar / angol) -->
                <ComboBox ItemsSource="{Binding Languages}"
                          SelectedItem="{Binding SelectedLanguage}"
                          DisplayMemberPath="Display"
                          Width="120" Height="32" Margin="0,0,10,0"
                          VerticalAlignment="Center"
                          ToolTip="{DynamicResource L.Language.Tooltip}" />

                <!-- Téma-váltó (sötét/világos) -->
                <Button Content="{Binding ThemeToggleLabel}" Command="{Binding ToggleThemeCommand}"
                        Padding="12,6" FontSize="12" Margin="0,0,10,0"
                        ToolTip="{DynamicResource L.Theme.Tooltip}" />

                <!-- Rendszergazda jelvény -->
                <Border Style="{StaticResource Chip}">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="{DynamicResource SuccessBrush}"
                                 VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="{DynamicResource L.AdminBadge}" Style="{StaticResource CaptionText}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <!-- ============ Fő tartalom ============ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.15*" MinWidth="320" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" MinWidth="300" />
            </Grid.ColumnDefinitions>

            <!-- Bal oldal: preset lista -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="{DynamicResource L.Presets}" Style="{StaticResource HeaderText}"
                               FontSize="15" Margin="2,0,0,10" />

                    <!-- Eszköztár -->
                    <WrapPanel Grid.Row="1" Margin="0,0,0,12">
                        <Button Content="{DynamicResource L.New}" Command="{Binding AddPresetCommand}" Margin="0,0,6,6" />
                        <Button Content="{DynamicResource L.Edit}" Command="{Binding EditPresetCommand}" Margin="0,0,6,6" />
                        <Button Content="{DynamicResource L.Duplicate}" Command="{Binding DuplicatePresetCommand}" Margin="0,0,6,6" />
                        <Button Content="{DynamicResource L.Delete}" Style="{StaticResource DangerButton}"
                                Command="{Binding DeletePresetCommand}" Margin="0,0,6,6" />
                        <Button Content="{DynamicResource L.Import}" Command="{Binding ImportCommand}" Margin="0,0,6,6" />
                        <Button Content="{DynamicResource L.Export}" Command="{Binding ExportCommand}" Margin="0,0,0,6" />
                    </WrapPanel>

                    <!-- Lista -->
                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding Presets}"
                             SelectedItem="{Binding SelectedPreset}"
                             ItemContainerStyle="{StaticResource PresetItem}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <DockPanel LastChildFill="False">
                                        <TextBlock Text="{Binding Name}" FontFamily="Segoe UI Semibold"
                                                   FontSize="14" DockPanel.Dock="Left" />
                                    </DockPanel>
                                    <TextBlock Text="{Binding Summary}" Style="{StaticResource CaptionText}"
                                               Margin="0,3,0,0" />
                                    <TextBlock Text="{Binding Notes}" Style="{StaticResource CaptionText}"
                                               FontStyle="Italic" TextTrimming="CharacterEllipsis"
                                               MaxHeight="18" Margin="0,3,0,0"
                                               Visibility="{Binding Notes, Converter={x:Static conv:StringToVisibilityConverter.Instance}}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBlock Grid.Row="3" Margin="2,10,0,0" Style="{StaticResource CaptionText}"
                               TextWrapping="Wrap">
                        <Run Text="{DynamicResource L.Storage}" />
                        <Run Text="{Binding StorePath, Mode=OneWay}" />
                    </TextBlock>
                </Grid>
            </Border>

            <!-- Jobb oldal: részletek + alkalmazás -->
            <Border Grid.Column="2" Style="{StaticResource Card}" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="{DynamicResource L.SelectedPreset}"
                               Style="{StaticResource HeaderText}" FontSize="15" Margin="0,0,0,12" />

                    <!-- Részletek -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <StackPanel Visibility="{Binding SelectedPreset, Converter={x:Static conv:NullToVisibilityConverter.Instance}}">
                                <TextBlock Text="{Binding SelectedPreset.Name}" FontSize="18"
                                           FontFamily="Segoe UI Semibold" TextWrapping="Wrap" />

                                <UniformGrid Columns="2" Margin="0,14,0,0">
                                    <StackPanel Margin="0,0,8,10">
                                        <TextBlock Text="{DynamicResource L.IpAddress}" Style="{StaticResource CaptionText}" />
                                        <TextBlock Text="{Binding SelectedPreset.Summary}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,0,10">
                                        <TextBlock Text="{DynamicResource L.SubnetMask}" Style="{StaticResource CaptionText}" />
                                        <TextBlock Text="{Binding SelectedPreset.SubnetMask}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,8,10">
                                        <TextBlock Text="{DynamicResource L.Gateway}" Style="{StaticResource CaptionText}" />
                                        <TextBlock Text="{Binding SelectedPreset.Gateway}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,0,10">
                                        <TextBlock Text="{DynamicResource L.PreferredDns}" Style="{StaticResource CaptionText}" />
                                        <TextBlock Text="{Binding SelectedPreset.PreferredDns}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,8,10">
                                        <TextBlock Text="{DynamicResource L.AlternateDns}" Style="{StaticResource CaptionText}" />
                                        <TextBlock Text="{Binding SelectedPreset.AlternateDns}" />
                                    </StackPanel>
                                </UniformGrid>

                                <TextBlock Text="{DynamicResource L.Notes}" Style="{StaticResource CaptionText}" Margin="0,4,0,2" />
                                <Border Background="{DynamicResource SurfaceAltBrush}" CornerRadius="6" Padding="10,8">
                                    <TextBlock Text="{Binding SelectedPreset.Notes}" TextWrapping="Wrap"
                                               MinHeight="30" />
                                </Border>
                            </StackPanel>

                            <TextBlock Text="{DynamicResource L.NoSelection}"
                                       Style="{StaticResource CaptionText}"
                                       Visibility="{Binding SelectedPreset, Converter={x:Static conv:NullToVisibilityConverter.InstanceInverse}}" />
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Adapter választás -->
                    <StackPanel Grid.Row="2" Margin="0,16,0,0">
                        <DockPanel Margin="0,0,0,4">
                            <TextBlock Text="{DynamicResource L.Adapter}" Style="{StaticResource CaptionText}"
                                       DockPanel.Dock="Left" VerticalAlignment="Center" />
                            <Button Content="{DynamicResource L.Refresh}" Command="{Binding RefreshAdaptersCommand}"
                                    DockPanel.Dock="Right" HorizontalAlignment="Right"
                                    Padding="10,4" FontSize="12" />
                        </DockPanel>
                        <ComboBox ItemsSource="{Binding Adapters}"
                                  SelectedItem="{Binding SelectedAdapter}"
                                  DisplayMemberPath="DisplayName" />
                        <TextBlock Style="{StaticResource CaptionText}" Margin="2,6,0,0" TextWrapping="Wrap">
                            <Run Text="{DynamicResource L.CurrentIp}" />
                            <Run Text="{Binding SelectedAdapter.CurrentIpv4, Mode=OneWay, TargetNullValue=—}" />
                        </TextBlock>
                    </StackPanel>

                    <!-- Alkalmazás gomb -->
                    <Button Grid.Row="3" Content="{DynamicResource L.Apply}"
                            Style="{StaticResource AccentButton}"
                            Command="{Binding ApplyPresetCommand}"
                            HorizontalAlignment="Stretch" Margin="0,16,0,0" />
                </Grid>
            </Border>
        </Grid>

        <!-- ============ Státuszsor ============ -->
        <Border Grid.Row="2" Margin="0,16,0,0"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                CornerRadius="6" Padding="12,8">
            <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding StatusIsError}" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Border>
    </Grid>
</Window>
