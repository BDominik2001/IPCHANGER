<Window x:Class="IpChanger.Views.ManualWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource L.Manual.Title}"
        Height="620" Width="560"
        MinHeight="460" MinWidth="460"
        WindowStartupLocation="CenterOwner"
        Icon="/Assets/app.ico"
        Background="{DynamicResource BackgroundBrush}"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="ManualHeading" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="FontFamily" Value="Segoe UI Semibold" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Margin" Value="0,18,0,6" />
        </Style>
        <Style x:Key="ManualBody" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="LineHeight" Value="20" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{DynamicResource L.Manual.Title}"
                   Style="{StaticResource HeaderText}" Margin="0,0,0,12" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
            <StackPanel>
                <TextBlock Style="{StaticResource ManualBody}" Text="{DynamicResource L.Manual.Intro}" />

                <TextBlock Style="{StaticResource ManualHeading}" Text="{DynamicResource L.Manual.S1Head}" />
                <TextBlock Style="{StaticResource ManualBody}" Text="{DynamicResource L.Manual.S1Body}" />

                <TextBlock Style="{StaticResource ManualHeading}" Text="{DynamicResource L.Manual.S2Head}" />
                <TextBlock Style="{StaticResource ManualBody}" Text="{DynamicResource L.Manual.S2Body}" />

                <TextBlock Style="{StaticResource ManualHeading}" Text="{DynamicResource L.Manual.S3Head}" />
                <TextBlock Style="{StaticResource ManualBody}" Text="{DynamicResource L.Manual.S3Body}" />

                <TextBlock Style="{StaticResource ManualHeading}" Text="{DynamicResource L.Manual.S4Head}" />
                <TextBlock Style="{StaticResource ManualBody}" Text="{DynamicResource L.Manual.S4Body}" />

                <TextBlock Style="{StaticResource ManualHeading}" Text="{DynamicResource L.Manual.S5Head}" />
                <TextBlock Style="{StaticResource ManualBody}" Text="{DynamicResource L.Manual.S5Body}" />
            </StackPanel>
        </ScrollViewer>

        <Button Grid.Row="2" Content="{DynamicResource L.Manual.Close}" Style="{StaticResource AccentButton}"
                HorizontalAlignment="Right" MinWidth="110" Margin="0,16,0,0"
                IsCancel="True" IsDefault="True" Click="OnClose" />
    </Grid>
</Window>
