<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Sötét téma – zöld akcentussal (paletta: #02ae6d, #01db7f, #8b8a89, #fcfcfc) -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#FF0E1512" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FF16211C" />
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="#FF1F2C26" />
    <SolidColorBrush x:Key="BorderBrush" Color="#FF2D3C34" />
    <SolidColorBrush x:Key="AccentBrush" Color="#FF02AE6D" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#FF01DB7F" />
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#FF029A5F" />
    <SolidColorBrush x:Key="TextBrush" Color="#FFFCFCFC" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="#FF9AA5A0" />
    <SolidColorBrush x:Key="DangerBrush" Color="#FFE5695B" />
    <SolidColorBrush x:Key="SuccessBrush" Color="#FF01DB7F" />
    <SolidColorBrush x:Key="WarningBrush" Color="#FFE0A83A" />

</ResourceDictionary>
