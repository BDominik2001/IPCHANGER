    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Világos téma paletta -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#FFF3F5F9" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="#FFEDF0F5" />
